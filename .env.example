# Travelpayouts API token (covers Aviasales flights + Hotellook hotels)
TP_TOKEN=your_travelpayouts_token

# Telegram
TG_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_chat_id

# Optional tuning (defaults shown)
ORIGINS=VIE,BTS
SCAN_WEEKENDS=8
TRIP_NIGHTS=3,4
TOTAL_THRESHOLD_EUR=250
ROLLING_DROP_PCT=0.25
HOTEL_SPLIT=1
DRY_RUN=false
